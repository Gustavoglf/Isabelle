<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pé de Fava</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #F5E6D3;
      color: #2F2F2F;
    }

    header {
      background: #6B3E26;
      color: white;
      padding: 20px;
      text-align: center;
    }

    .container {
      display: flex;
      gap: 20px;
      padding: 20px;
      flex-wrap: wrap;
    }

    .card {
      background: white;
      border-radius: 12px;
      padding: 15px;
      width: 250px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    button {
      background: #A63C06;
      color: white;
      border: none;
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
    }

    .kitchen {
      margin-top: 40px;
      background: #fff;
      padding: 20px;
      border-radius: 12px;
    }
  </style>
</head>
<body>

<header>
  <h1>🍽️ Restaurante Pé de Fava</h1>
  <p>Sabor artesanal e experiência moderna</p>
</header>

<section class="container" id="menu"></section>

<section style="padding:20px;">
  <h2>🛒 Finalizar Pedido</h2>

  <input type="number" id="mesa" placeholder="Número da mesa">

  <select id="pagamento">
    <option>Dinheiro</option>
    <option>Pix</option>
    <option>Cartão</option>
  </select>

  <button onclick="finalizarPedido()">Enviar Pedido</button>
</section>

<section class="kitchen">
  <h2>👨‍🍳 Pedidos da Cozinha</h2>
  <div id="pedidos"></div>
</section>

<script>
  const cardapio = [
    { nome: 'Hambúrguer Artesanal', preco: 28 },
    { nome: 'X-Bacon Supremo', preco: 32 },
    { nome: 'Frango Cremoso', preco: 38 },
    { nome: 'Brownie com Sorvete', preco: 22 }
  ];

  const carrinho = [];

  const menu = document.getElementById('menu');

  cardapio.forEach(item => {
    const div = document.createElement('div');
    div.className = 'card';

    div.innerHTML = `
      <h3>${item.nome}</h3>
      <p>R$ ${item.preco}</p>
      <button onclick="adicionar('${item.nome}', ${item.preco})">
        Adicionar
      </button>
    `;

    menu.appendChild(div);
  });

  function adicionar(nome, preco) {
    carrinho.push({ nome, preco });
    alert(nome + ' adicionado ao pedido');
  }

  function finalizarPedido() {
    const mesa = document.getElementById('mesa').value;
    const pagamento = document.getElementById('pagamento').value;

    const pedido = {
      numero: Math.floor(Math.random() * 9999),
      mesa,
      pagamento,
      itens: carrinho
    };

    mostrarPedido(pedido);
  }

  function mostrarPedido(pedido) {
    const pedidos = document.getElementById('pedidos');

    const div = document.createElement('div');
    div.className = 'card';

    div.innerHTML = `
      <h3>Comanda #${pedido.numero}</h3>
      <p>Mesa: ${pedido.mesa}</p>
      <p>Pagamento: ${pedido.pagamento}</p>
      <ul>
        ${pedido.itens.map(i => `<li>${i.nome}</li>`).join('')}
      </ul>
      <button>Finalizar</button>
    `;

    pedidos.appendChild(div);
  }
</script>

</body>
</html>
